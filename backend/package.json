{
  "name": "servicepratic-backend",
  "version": "1.0.0",
  "description": "Backend do ServicePratic - Sistema de gerenciamento de ordens de serviço",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "check": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:seed": "ts-node --esm prisma/seed.ts",
    "prisma:studio": "prisma studio",
    "prisma:format": "prisma format",
    "db:start": "docker compose up -d mysql",
    "db:stop": "docker compose down",
    "start": "node dist/server.js",
    "lint": "eslint 'src/**/*.{ts,js}'",
    "lint:fix": "eslint 'src/**/*.{ts,js}' --fix",
    "format": "prettier --write src"
  },
  "keywords": [
    "service",
    "order",
    "management"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^5.3.1",
    "@types/jsonwebtoken": "^9.0.10",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.14",
    "@types/express": "^4.17.18",
    "@types/node": "^20.5.7",
    "@typescript-eslint/eslint-plugin": "^6.6.0",
    "@typescript-eslint/parser": "^6.6.0",
    "eslint": "^8.48.0",
    "prettier": "^3.0.3",
    "prisma": "^5.3.1",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.22.4",
    "typescript": "5.2.2"
  }
}
